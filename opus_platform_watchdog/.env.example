# ============================================================
# Opus Platform Watchdog - Environment Configuration
# ============================================================
# Copy this file to .env and edit values.

# --- Watchdog UI auth ---
WATCHDOG_AUTH_USER=admin
WATCHDOG_AUTH_PASS=change_this_password

# --- Opus Trader connection (for HTTP probes) ---
OPUS_TRADER_BASE_URL=http://127.0.0.1:8000
OPUS_TRADER_AUTH_USER=admin
OPUS_TRADER_AUTH_PASS=your_opus_trader_password

# --- Paths to monitor (defaults match standard Opus Trader layout) ---
OPUS_RUNNER_LOG=/var/www/storage/runner.log
OPUS_APP_LOG=/var/www/storage/app.log
OPUS_BRIDGE_JSON=/var/www/storage/runtime_snapshot_bridge.json
OPUS_RUNNER_LOCK=/var/www/storage/runner.lock

# --- Watchdog settings ---
WATCHDOG_PORT=9000
WATCHDOG_DB_PATH=/var/www/opus_platform_watchdog/watchdog.db
LOG_SCAN_BYTES=65536

# --- Retention (days) ---
RETENTION_PROBE_RESULTS_DAYS=7
RETENTION_INCIDENTS_DAYS=30
RETENTION_HEALTH_DAYS=7
RETENTION_LATENCY_DAYS=3
