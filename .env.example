# =============================================================================
# Bybit Control Center - Environment Configuration
# =============================================================================

# =============================================================================
# Trading Environment Selection
# =============================================================================
# DEFAULT_TRADING_ENV: Which environment bots use by default
# Options: "testnet" (safe, fake money) or "mainnet" (REAL MONEY)
# IMPORTANT: Keep "testnet" as default for safety!
DEFAULT_TRADING_ENV=testnet

# =============================================================================
# TESTNET Credentials (RECOMMENDED - Start here!)
# =============================================================================
# Get testnet API keys from: https://testnet.bybit.com/app/user/api-management
# Testnet uses FAKE MONEY - safe for testing strategies

BYBIT_TESTNET_API_KEY=your_testnet_api_key_here
BYBIT_TESTNET_API_SECRET=your_testnet_api_secret_here
BYBIT_TESTNET_BASE_URL=https://api-testnet.bybit.com

# =============================================================================
# MAINNET Credentials (⚠️ REAL MONEY - USE WITH EXTREME CAUTION!)
# =============================================================================
# Get mainnet API keys from: https://www.bybit.com/app/user/api-management
# ⚠️ WARNING: Mainnet uses REAL MONEY! Only use after thorough testing on testnet.
#
# SECURITY RECOMMENDATIONS:
# 1. Use IP whitelist restrictions on your API keys
# 2. Enable only required permissions (Trade, Read)
# 3. Set withdrawal whitelist (do NOT allow withdrawals via API)
# 4. Start with small capital and conservative settings
# 5. Monitor logs closely for the first 24-48 hours

BYBIT_MAINNET_API_KEY=
BYBIT_MAINNET_API_SECRET=
BYBIT_MAINNET_BASE_URL=https://api.bybit.com

# =============================================================================
# Dashboard Security
# =============================================================================
# HTTP Basic Auth credentials for dashboard access
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change_this_password

# Optional IP allowlist for the dashboard/API. Leave empty to allow all IPs.
# If you run behind a reverse proxy, also set DASH_TRUSTED_PROXY_HOPS so
# Flask evaluates the forwarded client IP instead of the proxy hop itself.
# DASH_ALLOW_IPS=203.0.113.10,198.51.100.7

# Optional: trust this many proxy hops for X-Forwarded-For.
# Set to 1 for a single trusted reverse proxy; leave at 0 when not proxied.
# DASH_TRUSTED_PROXY_HOPS=1

# Optional localhost bypass for direct same-host development only.
# Leave disabled in reverse-proxy or remote deployments.
# DASH_LOCALHOST_BYPASS=0

# Websocket stream ownership. Keep "runner" for the default single-owner model.
# Use "app" only if you explicitly want the dashboard process to own streams,
# "both" only for debugging, and "none" to force REST/polling everywhere.
# BYBIT_STREAM_OWNER=runner

# =============================================================================
# AI Advisor (OpenRouter, read-only, opt-in)
# =============================================================================
# Global advisor toggle remains off by default. Enable only after setting the
# OpenRouter key out-of-band and opting in one or two bots first.
AI_ADVISOR_ENABLED=0
AI_ADVISOR_PROVIDER=openrouter
AI_ADVISOR_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Opus Trader
AI_ADVISOR_MODEL_PRIMARY=openai/gpt-5-nano
AI_ADVISOR_MODEL_ESCALATION=openai/gpt-5-mini
# AI_ADVISOR_ESCALATION_ENABLED=0
# AI_ADVISOR_TIMEOUT_SECONDS=8
# AI_ADVISOR_MAX_CALLS_PER_SYMBOL_WINDOW=2
# AI_ADVISOR_CALL_WINDOW_SECONDS=1800
# AI_ADVISOR_DEDUPE_TTL_SECONDS=900

# =============================================================================
# UI Configuration
# =============================================================================
# Label shown in the dashboard header
ENV_LABEL=Bybit Trading Bot

# =============================================================================
# Setup Instructions
# =============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in TESTNET credentials first:
#    - Sign up at https://testnet.bybit.com
#    - Create API key with Trade + Read permissions
#    - Add key/secret to BYBIT_TESTNET_API_KEY and BYBIT_TESTNET_API_SECRET
#
# 3. Test thoroughly on testnet:
#    - Run bots in paper trading mode first
#    - Then enable live trading on testnet (fake money)
#    - Monitor for at least 24-48 hours
#
# 4. Only after successful testnet testing, optionally fill in MAINNET credentials:
#    - ⚠️ This is REAL MONEY - be extremely careful!
#    - Start with minimal capital
#    - Use conservative risk settings
#    - Enable all available security features on Bybit
#
# 5. Change BASIC_AUTH_PASS to a strong password
#
# 6. Restart the application for changes to take effect
#
