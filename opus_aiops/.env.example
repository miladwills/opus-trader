# ============================================================
# Opus AI Ops Service - Environment Configuration
# ============================================================
# Copy this file to .env and edit values.

# --- AI Ops UI auth (separate from trader and watchdog) ---
AIOPS_AUTH_USER=admin
AIOPS_AUTH_PASS=change_this_password

# --- AI Ops service ---
AIOPS_PORT=9100
AIOPS_DB_PATH=/var/www/opus_aiops/aiops.db

# --- Opus Trader connection (read-only) ---
OPUS_TRADER_BASE_URL=http://127.0.0.1:8000
OPUS_TRADER_AUTH_USER=admin
OPUS_TRADER_AUTH_PASS=your_trader_password

# --- Watchdog connection (read-only) ---
WATCHDOG_BASE_URL=http://127.0.0.1:9000
WATCHDOG_AUTH_USER=admin
WATCHDOG_AUTH_PASS=your_watchdog_password

# --- Storage paths (read-only access) ---
OPUS_STORAGE_PATH=/var/www/storage

# --- Collection cadence (seconds) ---
FAST_LANE_INTERVAL_SEC=15
MEDIUM_LANE_INTERVAL_SEC=30
SLOW_LANE_INTERVAL_SEC=60

# --- Limits ---
LOG_SCAN_BYTES=65536

# --- Retention (days) ---
RETENTION_SNAPSHOTS_DAYS=7
RETENTION_TRIAGE_DAYS=30
RETENTION_AUDIT_DAYS=90

# --- Triage ---
TRIAGE_AUTO_RESOLVE_SEC=600
CORRELATOR_WINDOW_SIZE=10
